/* CEELL device tree overlay for MR-CANHUBK3
 * Replaces default storage partition with config + storage
 */

&mx25l6433f {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/delete-node/ partition@0;

		config_partition: partition@0 {
			label = "config";
			reg = <0x0 0x10000>;
		};

		storage_partition: partition@10000 {
			label = "storage";
			reg = <0x10000 0xF0000>;
		};
	};
};
