mainmenu "CEELL Middleware Configuration"

menu "CEELL Services"

config CEELL_MAX_SERVICES
	int "Maximum number of services per node"
	default 4

config CEELL_MSG_PORT
	int "UDP port for service messaging"
	default 5556

config CEELL_PEER_TIMEOUT_MS
	int "Peer expiry timeout in milliseconds"
	default 5000

config CEELL_TEST_ECHO_SERVICE
	bool "Enable built-in echo test service"
	default n

endmenu

menu "CEELL Discovery"

config CEELL_DISCOVERY_PORT
	int "UDP port for discovery"
	default 5555

config CEELL_DISCOVERY_GROUP
	string "Multicast group address"
	default "224.0.1.100"

config CEELL_DISCOVERY_INTERVAL_MS
	int "Announcement interval in milliseconds"
	default 1000

config CEELL_DISCOVERY_MAX_PEERS
	int "Maximum number of tracked peers"
	default 8

endmenu

menu "CEELL Node Identity"

config CEELL_NODE_ID_DEFAULT
	int "Default node ID (used if flash config is empty)"
	default 0

config CEELL_NODE_ROLE_DEFAULT
	string "Default node role"
	default "unknown"

config CEELL_NODE_NAME_DEFAULT
	string "Default node name"
	default "ceell-unprovisioned"

config CEELL_NODE_IP_DEFAULT
	string "Default IP address"
	default "192.168.1.100"

config CEELL_NODE_NETMASK_DEFAULT
	string "Default netmask"
	default "255.255.255.0"

endmenu

menu "CEELL OTA Firmware Updates"

config CEELL_OTA
	bool "Enable OTA firmware update client"
	default n
	depends on BOOTLOADER_MCUBOOT
	depends on NET_TCP
	depends on HTTP_CLIENT
	depends on IMG_MANAGER
	depends on STREAM_FLASH
	help
	  Enable over-the-air firmware update support. The OTA client
	  periodically polls an HTTP server for a firmware manifest,
	  downloads new images to the secondary slot, and triggers
	  MCUboot to swap on reboot.

config CEELL_OTA_SERVER_HOST
	string "OTA server IP address"
	default "192.168.1.1"
	depends on CEELL_OTA

config CEELL_OTA_SERVER_PORT
	int "OTA server HTTP port"
	default 8080
	depends on CEELL_OTA

config CEELL_OTA_CHECK_INTERVAL_SEC
	int "Seconds between automatic update checks"
	default 300
	depends on CEELL_OTA

config CEELL_OTA_MANIFEST_PATH
	string "HTTP path to firmware manifest JSON"
	default "/firmware/latest.json"
	depends on CEELL_OTA

config CEELL_OTA_AUTO_CONFIRM
	bool "Automatically confirm image on successful boot"
	default y
	depends on CEELL_OTA
	help
	  When enabled, the running firmware is automatically confirmed
	  after a successful boot. If disabled, the application must
	  call boot_write_img_confirmed() explicitly — otherwise MCUboot
	  will revert to the previous image on the next reboot.

config CEELL_OTA_USE_TLS
	bool "Use HTTPS for OTA downloads"
	default n
	depends on CEELL_OTA
	depends on TLS_CREDENTIALS
	help
	  Enable TLS for OTA downloads. Requires additional heap (~49KB)
	  and a TLS credential configured for the server certificate.

endmenu

menu "CEELL Safety Messaging"

config CEELL_MSG_DISPATCHER_PRIORITY
	int "Dispatcher thread priority"
	default 5
	help
	  Priority of the message dispatcher thread. This thread reads
	  incoming UDP packets and routes them to per-priority queues.
	  Should be higher priority (lower number) than normal handlers.

config CEELL_MSG_CRITICAL_PRIORITY
	int "Critical message handler thread priority"
	default 2
	help
	  Priority of the thread that processes CRITICAL (safety) messages.
	  This is the highest priority handler — used for brake, steer, and
	  other safety-critical commands. Must be lower (higher priority)
	  than all other handler threads.

config CEELL_MSG_NORMAL_PRIORITY
	int "Normal message handler thread priority"
	default 7
	help
	  Priority of the thread that processes NORMAL (standard) messages.
	  Used for regular service requests and responses.

config CEELL_MSG_BULK_PRIORITY
	int "Bulk message handler thread priority"
	default 10
	help
	  Priority of the thread that processes BULK (low priority) messages.
	  Used for diagnostics, OTA status, and telemetry. Runs at the
	  lowest priority of all handler threads.

config CEELL_MSG_QUEUE_DEPTH
	int "Per-priority message queue depth"
	default 8
	help
	  Maximum number of messages that can be queued for each priority
	  level (CRITICAL, NORMAL, BULK). If a queue is full, incoming
	  messages of that priority are dropped with an error response.

endmenu

menu "CEELL Timing & Determinism"

config CEELL_TIMING
	bool "Enable timing measurement framework"
	default y
	help
	  Enable the timing measurement subsystem. Provides a ring buffer
	  of timing samples with per-label statistics (min/max/avg).
	  Uses the hardware cycle counter for sub-microsecond precision.

config CEELL_TIMING_SAMPLES
	int "Number of timing sample slots in ring buffer"
	default 64
	depends on CEELL_TIMING
	help
	  Size of the ring buffer that stores timing measurements.
	  Older samples are overwritten when the buffer is full.

config CEELL_TIMING_BUDGETS
	bool "Enable timing budget checks"
	default y
	depends on CEELL_TIMING
	help
	  Enable timing budgets for critical code paths. Each budget
	  defines a maximum acceptable duration; violations are counted
	  and repeated consecutive violations (3+) trigger a warning
	  that would escalate to safe state in production.

config CEELL_TSN
	bool "Enable TSN traffic class mapping"
	default n
	help
	  Enable IEEE 802.1Q TSN (Time-Sensitive Networking) traffic class
	  mapping. Maps CEELL message priorities to 802.1Q PCP values.
	  Currently stubbed — requires TSN-capable hardware (e.g. S32K5xx
	  ENETC) for actual queue scheduling.

endmenu

menu "CEELL Redundancy & Fault Tolerance"

config CEELL_MSG_REDUNDANT
	bool "Enable dual-path redundant messaging"
	default n
	help
	  Enable a secondary UDP socket for redundant message delivery.
	  Messages are sent on both the primary and secondary paths.
	  A deduplication ring buffer discards duplicate sequence numbers
	  received on either path.

config CEELL_MSG_PORT_SECONDARY
	int "Secondary UDP port for redundant messaging"
	default 5557
	depends on CEELL_MSG_REDUNDANT
	help
	  UDP port number for the secondary redundant messaging path.

config CEELL_SAFE_STATE
	bool "Enable safe state management"
	default y
	help
	  Enable the safe state manager. Provides an atomic safe-state
	  flag with callback notification. Modules can trigger safe state
	  when critical faults are detected (peer loss, deadline exceeded,
	  communication failure).

config CEELL_WATCHDOG
	bool "Enable software watchdog"
	default n
	depends on CEELL_SAFE_STATE
	help
	  Enable a software watchdog timer. If ceell_watchdog_feed() is not
	  called within the configured timeout, the watchdog triggers safe
	  state via ceell_safe_state_trigger(). The lifecycle loop should
	  call ceell_watchdog_feed() each tick.

config CEELL_WATCHDOG_TIMEOUT_MS
	int "Software watchdog timeout in milliseconds"
	default 10000
	depends on CEELL_WATCHDOG
	help
	  Maximum time between watchdog feeds before safe state is triggered.
	  Should be set to a value larger than the lifecycle tick interval.

endmenu

source "Kconfig.zephyr"
